# Copy to .env.local and fill with your project values (never commit .env.local).
# Supabase → Project Settings → API Keys
#
# SUPABASE_SERVICE_ROLE_KEY = elevated server key only. Valid options:
#   - Secret API key: sb_secret_…  (recommended on newer projects)
#   - Legacy JWT: eyJ… from the "service_role" row (Legacy anon / service_role keys)
# Do NOT use the publishable key (sb_publishable_…) here — signups will fail with 500.
#
# Mux playback ID for /intro video (required for the intro page).
# Upload at https://dashboard.mux.com → Assets → copy Playback ID.
# NEXT_PUBLIC_MUX_INTRO_PLAYBACK_ID=
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_secret_or_legacy_service_role_key
