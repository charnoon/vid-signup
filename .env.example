# Copy to .env.local and fill with your project values (never commit .env.local).

# Google Sheets signup storage
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your_google_sheet_id

# Preview video gate (/preview) — required in production
INTRO_ACCESS_PASSWORD=your_intro_password
# Optional: separate secret for signing the access cookie
# INTRO_ACCESS_SECRET=long_random_string
